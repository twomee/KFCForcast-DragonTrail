{
  "info": {
    "_postman_id": "9f5dfd2d-9ae6-4b35-9b53-0a9b51d29c1f",
    "name": "KFC Forecast",
    "description": "API collection for the KFC Forecast home assignment. Run the health check, list stores, generate forecasts, and read forecasts by store/date.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "List Stores",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/stores",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "stores"]
        }
      },
      "response": []
    },
    {
      "name": "Generate Forecasts",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"forecast_date\": \"{{forecastDate}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/forecasts/generate",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "forecasts", "generate"]
        }
      },
      "response": []
    },
    {
      "name": "Read Forecasts By Store And Date",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/forecasts?store_id={{storeId}}&date={{forecastDate}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "forecasts"],
          "query": [
            {
              "key": "store_id",
              "value": "{{storeId}}"
            },
            {
              "key": "date",
              "value": "{{forecastDate}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Read Forecasts For Missing Store",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/forecasts?store_id=999999&date={{forecastDate}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "forecasts"],
          "query": [
            {
              "key": "store_id",
              "value": "999999"
            },
            {
              "key": "date",
              "value": "{{forecastDate}}"
            }
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "storeId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "forecastDate",
      "value": "2026-05-06",
      "type": "string"
    }
  ]
}
